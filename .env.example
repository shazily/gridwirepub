# =============================================================================
# Gridwire — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in real values before deploying:
#
#     cp .env.example .env
#
# NEVER commit your real `.env`. It is already git-ignored.
# Generate strong random values with:  openssl rand -hex 32
# =============================================================================

# -----------------------------------------------------------------------------
# Deployment profile
# -----------------------------------------------------------------------------
# onprem = bundled Postgres + Auth + Kong (see deploy/on-prem/README.md).
# Omit or use cloud values when pointing at an external Supabase-compatible API.
# GRIDWIRE_DEPLOYMENT=onprem
# DEPLOYMENT_MODE=onprem

# -----------------------------------------------------------------------------
# Backend connection (Postgres + Auth + REST)
# -----------------------------------------------------------------------------
# Point these at YOUR OWN self-hosted backend. For a fully on-premise stack see
# DEPLOYMENT.md → "Self-host the backend". When running the bundled backend via
# docker compose, the URL is the API gateway on your host, e.g. http://kong:8000
# inside the compose network or https://api.your-company.com from outside.
SUPABASE_URL=https://api.your-company.com
VITE_SUPABASE_URL=https://api.your-company.com

# Public (publishable / "anon") API key issued by your backend. Safe for the browser.
SUPABASE_PUBLISHABLE_KEY=replace-with-your-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=replace-with-your-anon-key

# Server-side privileged key. Used only by the portal server process for admin
# operations. KEEP SECRET — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# -----------------------------------------------------------------------------
# Field encryption (data at rest)
# -----------------------------------------------------------------------------
# 64 hex characters (32 bytes) for AES-256-GCM `encrypt` fields.
# Generate:  openssl rand -hex 32
# REQUIRED in production — portal refuses to start without a valid key.
# KEEP STABLE across deploys — rotating makes existing encrypted values undecryptable.
FIELD_ENCRYPTION_KEY=replace-with-64-hex-chars

# Local dev only: allow weak/placeholder FIELD_ENCRYPTION_KEY (logs a warning).
# Never set in production.
# FIELD_ENCRYPTION_ALLOW_INSECURE_DEV=true

# -----------------------------------------------------------------------------
# Companion ingestion worker
# -----------------------------------------------------------------------------
# Shared token the worker uses to authenticate to the portal's /api/public/worker/*
# endpoints. Must match on both the portal and worker. Generate: openssl rand -hex 32
WORKER_INGEST_TOKEN=replace-with-shared-worker-token

# Worker poll schedule (cron syntax). Default: every 5 minutes.
POLL_CRON=*/5 * * * *

# Per-connector SFTP credentials as JSON, keyed by connector id. Credentials
# never touch the portal database — they live only on the worker.
# Example: {"<connector-id>":{"password":"s3cret"}}
# See docs/connector-credentials-migration.md
SFTP_SECRETS={}

# Worker SSRF guard: block private/link-local connector hosts (default).
# Set true only for on-prem workers connecting to internal SFTP servers.
# ALLOW_INTERNAL_CONNECTOR_HOSTS=false

# Port for the worker's internal health/readiness server (liveness: /healthz,
# readiness: /readyz). Used by container HEALTHCHECK and Kubernetes probes.
HEALTH_PORT=8080

# Optional: require a Bearer token to scrape /api/public/metrics (Prometheus).
# REQUIRED in production — the endpoint returns 401 when unset.
METRICS_TOKEN=replace-with-openssl-rand-hex-32

# Public dataset API rate limits (requests per minute per API key or client IP).
API_RATE_LIMIT_PER_MIN=60
API_RATE_LIMIT_BURST=20

# Direct Postgres URL for idempotent migrations (deploy.ps1 / apply-migrations.ps1).
# On-prem bootstrap sets this automatically. Example:
# postgresql://postgres:PASSWORD@127.0.0.1:54332/postgres
DATABASE_URL=

# On-prem only (generated by bootstrap-onprem.ps1 — required when GRIDWIRE_DEPLOYMENT=onprem)
# POSTGRES_PASSWORD=replace-with-strong-password
# JWT_SECRET=replace-with-openssl-rand-hex-48
# GRIDWIRE_HOST_PORT=3020
# GRIDWIRE_API_PORT=3040
# GRIDWIRE_DB_PORT=54332

# Object storage (MinIO in on-prem compose; S3-compatible endpoint in cloud)
# STORAGE_ACCESS_KEY=gridwire
# STORAGE_SECRET_KEY=replace-with-openssl-rand-hex-32
# MINIO_ROOT_PASSWORD=replace-with-openssl-rand-hex-32
# STORAGE_BUCKET=gridwire

# Deployment profile (baked into the portal bundle at Docker build time).
# onprem = email/password auth, no OAuth stubs. Use for self-hosted stacks.
VITE_DEPLOYMENT_MODE=onprem

# Promotional marketing homepage — operator demo site ONLY (not for orgs cloning the repo).
# Leave false (or omit) for standard self-hosted deployments.
VITE_SHOW_MARKETING=false

# Google Analytics — marketing homepage only (when VITE_SHOW_MARKETING=true).
VITE_GA_MEASUREMENT_ID=

# Public portal URL — auth redirects, alert emails, email-ingest webhook display, and OpenAPI/Swagger server URL.
PUBLIC_APP_URL=https://data.your-company.com
SITE_URL=https://data.your-company.com

# Marketing site "Get the Repo" link (baked into the portal bundle at Docker build).
VITE_GITHUB_REPO_URL=https://github.com/shazily/gridwirepub

# Host loopback port for the portal container (change if 3020 is already in use).
GRIDWIRE_HOST_PORT=3020

# Self-hosted SMTP / Postmark (optional — required for password reset and alert emails).
# Postmark: use Server API token for SMTP_USER and SMTP_PASS.
# Each EMAIL_FROM_* must be a verified Sender Signature in Postmark.
# SKIP_EMAIL=true disables all outbound mail from the portal worker.
SKIP_EMAIL=false
POSTMARK_API_TOKEN=
POSTMARK_API_URL=https://api.postmarkapp.com/email
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_TAG=gridwire
EMAIL_FROM_NOREPLY=noreply@your-company.com
EMAIL_FROM_NOTIFICATIONS=notifications@your-company.com
EMAIL_FROM_SUPPORT=support@your-company.com
EMAIL_FROM_INFO=info@your-company.com
EMAIL_FROM_AUTH=auth@your-company.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@your-company.com
SMTP_SECURE=false
SMTP_SENDER_NAME=Gridwire

# Email ingest — dedicated workspace addresses and malware scanning.
INGEST_EMAIL_DOMAIN=ingest.yourdomain.com
VITE_INGEST_EMAIL_DOMAIN=ingest.yourdomain.com
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
# When true, email ingest and scans fail closed if CLAMAV_HOST is unset or unreachable.
# Recommended for production internet-exposed deployments with email ingest enabled.
# CLAMAV_REQUIRED=true

# REQUIRED for any internet-exposed deployment (NODE_ENV=production or on-prem).
# Inbound gateway POSTs must include X-Gridwire-Webhook-Secret or Authorization: Bearer.
# Generate: openssl rand -hex 32
INBOUND_WEBHOOK_SECRET=replace-with-openssl-rand-hex-32

# Postmark inbound route (/api/public/inbound/postmark): HMAC signature secret.
# Defaults to INBOUND_WEBHOOK_SECRET when unset. Postmark sends X-Postmark-Signature
# (Base64 HMAC-SHA256 of the raw JSON body). Mandatory in production for Postmark.
# POSTMARK_WEBHOOK_SECRET=

# Rate limits for unauthenticated public endpoints (per client IP per minute).
# PUBLIC_RATE_LIMIT_PER_MIN=60
# PUBLIC_RATE_LIMIT_BURST=30

# Local dev default (override both URLs above when deploying behind a real hostname or tunnel).
# PUBLIC_APP_URL=http://127.0.0.1:3020
# SITE_URL=http://127.0.0.1:3020
