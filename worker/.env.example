# Gridwire portal base URL (no trailing slash)
PORTAL_URL=https://your-gridwire-host.example.com

# Shared worker token — must match the WORKER_INGEST_TOKEN secret in the portal
WORKER_INGEST_TOKEN=replace-with-portal-worker-token

# How often to poll (cron syntax). Default: every 5 minutes.
POLL_CRON=*/5 * * * *

# Where to persist "already ingested" state inside the container.
STATE_FILE=/data/state.json

# Per-connector SFTP credentials as JSON, keyed by connector id.
# Find connector ids in the portal (Connectors page) or the API response.
# Example:
# SFTP_SECRETS={"<connector-id>":{"password":"s3cret"},"<other-id>":{"privateKey":"-----BEGIN..."}}
SFTP_SECRETS={}

# Port for the worker's internal health/readiness server.
# Liveness: GET /healthz · Readiness: GET /readyz (portal reachable recently).
# Used by container HEALTHCHECK and Kubernetes probes. Set 0 to disable.
HEALTH_PORT=8080

# Optional: require a Bearer token to scrape the worker /metrics endpoint.
METRICS_TOKEN=
